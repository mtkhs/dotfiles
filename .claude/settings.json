            "command": "printf '{\"hookSpecificOutput\":{\"hookEventName\":\"UserPromptSubmit\",\"additionalContext\":\"Now: %s\"}}\\n' \"$(date '+%Y-%m-%d %H:%M:%S %a')\"",
